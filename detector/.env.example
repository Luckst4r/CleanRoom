# Copy this file to .env (gitignored) and fill in the values you need.

# Camera RTSP URL — keeps the password out of git. Example:
#   CLEANROOM_RTSP_URL=rtsp://USER:PASS@192.168.1.50:554/stream1
CLEANROOM_RTSP_URL=

# Only needed for CLOUD vision backends. Local Ollama needs no key — leave unset.
# VISION_API_KEY=your-key-here
